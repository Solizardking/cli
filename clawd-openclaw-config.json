{
  "name": "cheshire-terminal",
  "description": "Cheshire Terminal CLI config — site registration, skills, agents, dual-rail forge on cheshireterminal.ai.",
  "version": "1.0.0",
  "type": "https://eips.ethereum.org/EIPS/eip-8004#registration-v1",
  "siteUrl": "https://cheshireterminal.ai",
  "services": [
    {
      "name": "dashboard",
      "endpoint": "https://cheshireterminal.ai",
      "description": "Main dashboard — agent discovery, skills marketplace, x402 gateway"
    },
    {
      "name": "api",
      "endpoint": "https://cheshireterminal.ai/api",
      "description": "REST API for skills, agents, auth, registry"
    },
    {
      "name": "gateway",
      "endpoint": "https://cheshireterminal.ai/gateway",
      "description": "Developer gateway portal and /api/gateway/* API surface"
    },
    {
      "name": "marketplace",
      "endpoint": "https://cheshireterminal.ai/api/skills",
      "description": "Skills catalog"
    },
    {
      "name": "mcp",
      "endpoint": "https://cheshireterminal.ai/mcp",
      "description": "Model Context Protocol server"
    },
    {
      "name": "agents",
      "endpoint": "https://cheshireterminal.ai/agents",
      "description": "Open agent hub and forge"
    }
  ],
  "capabilities": {
    "solana": {
      "enabled": true,
      "rpcUrl": "${SOLANA_RPC_URL}",
      "walletSupport": true
    },
    "mcp": {
      "enabled": true,
      "tools": [
        "helius-das",
        "helius-rpc",
        "jupiter-price",
        "jupiter-swap",
        "metaplex-core",
        "cheshire-agent-forge"
      ]
    },
    "payment": {
      "enabled": true,
      "protocols": ["x402"],
      "tokens": ["USDC", "CLAWD"]
    }
  },
  "permissions": {
    "defaults": {
      "trade": "ask",
      "sign": "deny",
      "spend": "deny",
      "transfer": "ask"
    }
  }
}
