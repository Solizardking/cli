{
  "name": "cheshire-terminal-cli",
  "version": "1.1.0",
  "description": "Terminal into the clawd. Official Cheshire Terminal CLI — sync /skills /agents /agent-registry, SIWS auth, register every catalog agent to the frontend. Hub: https://cheshireterminal.ai/cli · gateway: https://cheshireterminal.ai/gateway",
  "type": "module",
  "license": "MIT",
  "author": "Cheshire Terminal <operators@cheshireterminal.ai>",
  "contributors": [
    "x402solana"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Solizardking/cheshire-terminal.git",
    "directory": "cli"
  },
  "homepage": "https://cheshireterminal.ai/cli",
  "bugs": {
    "url": "https://github.com/Solizardking/cheshire-terminal/issues"
  },
  "keywords": [
    "cheshire-terminal",
    "cheshire-cli",
    "cheshire-terminal-cli",
    "solana",
    "cli",
    "siws",
    "agent-registry",
    "skills",
    "gateway",
    "x402",
    "mcp",
    "agents",
    "metaplex",
    "robinhood-chain"
  ],
  "bin": {
    "cheshire-cli": "bin/cheshire-cli.js",
    "cheshire-terminal-cli": "bin/cheshire-cli.js",
    "ct-cli": "bin/cheshire-cli.js",
    "clawd-cli": "bin/cheshire-cli.js"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./package.json": "./package.json",
    "./registration": "./cheshire-registration.json",
    "./config": "./cheshire-config.json"
  },
  "main": "./src/index.mjs",
  "files": [
    "bin",
    "cheshire-cli.mjs",
    "cheshire-cli.sh",
    "cheshire-register.mjs",
    "clawd-cli.sh",
    "clawd-connect.sh",
    "src",
    "assets",
    "cheshire-registration.json",
    "cheshire-config.json",
    "clawd-registration.json",
    "clawd-openclaw-config.json",
    "solana-clawd-registration.json",
    "README.md",
    "LICENSE"
  ],
  "optionalDependencies": {
    "cheshire-terminal-agents": "^1.48.0"
  },
  "scripts": {
    "start": "node ./bin/cheshire-cli.js",
    "cli": "node ./bin/cheshire-cli.js",
    "help": "node ./bin/cheshire-cli.js help",
    "status": "node ./bin/cheshire-cli.js status",
    "sync": "node ./bin/cheshire-cli.js sync",
    "test": "node --test ./cheshire-cli.test.mjs",
    "prepack": "node --check bin/cheshire-cli.js && node --check cheshire-cli.mjs && node --check src/config.mjs && node --check src/client.mjs && node --check src/catalog.mjs && node --check src/commands.mjs && node --check src/index.mjs",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": false
}
